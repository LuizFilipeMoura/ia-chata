{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "types": ["vitest/globals", "@testing-library/jest-dom"],
    "paths": {
      "/shared/game-state.js": ["./client/shared.d.ts"],
      "/shared/battle-view.js": ["./client/shared.d.ts"],
      "/shared/glossary.js": ["./client/shared.d.ts"],
      "/shared/field.js": ["./client/shared.d.ts"],
      "/shared/unit-kinds.js": ["./client/shared.d.ts"],
      "/shared/combat.js": ["./client/shared.d.ts"]
    }
  },
  "include": ["client/src", "client/shared.d.ts"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
